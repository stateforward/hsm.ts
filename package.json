{
  "name": "@stateforward/hsm.ts",
  "version": "0.1.0",
  "description": "Standalone TypeScript hierarchical state machine library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./kind": {
      "types": "./dist/kind.d.ts",
      "import": "./dist/kind.js",
      "require": "./dist/kind.cjs"
    },
    "./muid": {
      "types": "./dist/muid.d.ts",
      "import": "./dist/muid.js",
      "require": "./dist/muid.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "benchmark:muid": "tsx scripts/benchmark-muid.ts",
    "build": "tsup",
    "coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include=src/hsm.ts --test-coverage-include=src/kind.ts --test-coverage-include=src/muid.ts tests/runtime-ported/*.test.ts",
    "test:parity": "tsx --test tests/runtime-ported/*.test.ts",
    "test:types": "for config in tests/types/*/tsconfig.json; do tsc -p \"$config\" --pretty false || exit 1; done",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run test:types && npm run build && npm run test:parity"
  },
  "keywords": [
    "state-machine",
    "hsm",
    "typescript",
    "fsm",
    "hierarchical"
  ],
  "author": "HSM Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stateforward/hsm.ts.git"
  },
  "bugs": {
    "url": "https://github.com/stateforward/hsm.ts/issues"
  },
  "homepage": "https://github.com/stateforward/hsm.ts#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
